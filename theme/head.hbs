<script>
  document.addEventListener('DOMContentLoaded', function () {
    var rightButtons = document.querySelector('.right-buttons');
    if (!rightButtons || document.querySelector('.build-meta')) return;

    var versionUrl = (typeof path_to_root === 'string' ? path_to_root : '') + 'version.json';

    fetch(versionUrl)
      .then(function (response) {
        if (!response.ok) throw new Error('Cannot load version metadata');
        return response.json();
      })
      .then(function (data) {
        var commitSha = data && data.commitSha;
        var commitShort = data && data.commitShort;
        var buildDate = data && data.buildDate;
        if (!commitSha || !commitShort || !buildDate) return;

        var meta = document.createElement('span');
        meta.className = 'build-meta';
        meta.innerHTML = 'v' + buildDate + ' · <a href="https://github.com/skywirex/c101.skywirex.com/commit/' + commitSha + '" target="_blank" rel="noopener noreferrer">' + commitShort + '</a>';

        var firstButton = rightButtons.firstElementChild;
        if (firstButton) {
          rightButtons.insertBefore(meta, firstButton);
        } else {
          rightButtons.appendChild(meta);
        }
      })
      .catch(function () {
      });
  });
</script>
