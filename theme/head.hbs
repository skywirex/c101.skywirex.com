<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-4GL9F6JJ2G"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-4GL9F6JJ2G');
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var rightButtons = document.querySelector('.right-buttons');
    if (!rightButtons || document.querySelector('.build-meta')) return;

    fetch('https://api.github.com/repos/skywirex/c101.skywirex.com/commits/master', {
      headers: { 'Accept': 'application/vnd.github+json' }
    })
      .then(function (response) {
        if (!response.ok) throw new Error('Cannot load commit metadata');
        return response.json();
      })
      .then(function (data) {
        var commitSha = data && data.sha;
        var commitShort = commitSha ? commitSha.substring(0, 7) : null;
        var commitDateRaw = data && data.commit && data.commit.committer && data.commit.committer.date;
        if (!commitSha || !commitShort || !commitDateRaw) return;

        var dateObj = new Date(commitDateRaw);
        var commitDate = new Intl.DateTimeFormat('en-CA', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
          timeZone: 'Asia/Ho_Chi_Minh'
        }).format(dateObj).replace(/-/g, '');

        var meta = document.createElement('span');
        meta.className = 'build-meta';
        meta.innerHTML = 'v' + commitDate + ' · <a href="https://github.com/skywirex/c101.skywirex.com/commit/' + commitSha + '" target="_blank" rel="noopener noreferrer">' + commitShort + '</a>';

        var firstButton = rightButtons.firstElementChild;
        if (firstButton) {
          rightButtons.insertBefore(meta, firstButton);
        } else {
          rightButtons.appendChild(meta);
        }
      })
      .catch(function () {
      });
  });
</script>
